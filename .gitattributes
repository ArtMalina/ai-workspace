# Force CRLF line endings for all text files
* text=auto eol=crlf

# Explicitly declare text files
*.py    text eol=crlf
*.ts    text eol=crlf
*.svelte text eol=crlf
*.js    text eol=crlf
*.css   text eol=crlf
*.html  text eol=crlf
*.json  text eol=crlf
*.toml  text eol=crlf
*.yaml  text eol=crlf
*.yml   text eol=crlf
*.md    text eol=crlf
*.env   text eol=crlf
*.env.* text eol=crlf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.lock  text eol=crlf
